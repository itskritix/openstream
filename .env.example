# ─────────────────────────────────────────────────────────────
# You almost certainly only need these two.
# ─────────────────────────────────────────────────────────────
ADMIN_USER=admin
ADMIN_PASS=change-me-please

# ─────────────────────────────────────────────────────────────
# Everything below is OPTIONAL.
# If left unset, OpenStream generates these on first boot and saves
# them to the data volume (see the logs for the values). Only set
# them if you want to pin specific values.
# ─────────────────────────────────────────────────────────────

# INGEST_KEY=            # OBS publish password (auto-generated; shown in dashboard)
# SESSION_SECRET=        # signs the login cookie (auto-generated)
# ENCRYPTION_KEY=        # 64 hex chars — encrypts saved stream keys (auto-generated)

# ─── Wiring (defaults are correct for docker-compose) ───
# PORT=3000
# MEDIAMTX_API=http://mediamtx:9997
# MEDIAMTX_RTMP=rtmp://mediamtx:1935
# INGEST_PATH=live
# DB_PATH=/data/openstream.sqlite
# POLL_INTERVAL_MS=1500
